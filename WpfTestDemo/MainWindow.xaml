                            <MyRouteEvent:TimeButtonUserControl x:Name="myTimeButton" Margin="10" />
                        </StackPanel>

                        <!--  附加属性  -->
                        <StackPanel
                            Grid.Column="1"
                            Margin="10,0"
                            Orientation="Horizontal">
                            <PasswordBox
                                x:Name="pwdBox"
                                Width="auto"
                                Height="30"
                                MinWidth="50"
                                Padding="5"
                                MyDependency:PassWordAttached.Pwd="{Binding MyPassWord, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource PasswordBoxStyle}"
                                Tag="请输入密码" />
                            <TextBox
                                x:Name="pwdText"
                                Width="auto"
                                Height="30"
                                MinWidth="50"
                                Margin="10,0"
                                Padding="5,0"
                                VerticalContentAlignment="Center"
                                Style="{DynamicResource TextBoxStyle1}"
                                Text="{Binding MyPassWord}" />
                            <Button
                                x:Name="ShowPwd"
                                Height="30"
                                MinWidth="50"
                                Click="ShowPwd_Click"
                                Content="绑定源" />
                            <!--<PasswordBox
                                Height="30"
                                MinWidth="50"
                                Style="{StaticResource PasswordBoxStyle}"
                                Tag="原生密码输入框" />-->
                        </StackPanel>

                        <!--  动画  -->
                        <Canvas
                            Grid.Column="2"
                            Width="300"
                            Height="100">
                            <Button
                                x:Name="myButton"
                                Canvas.Left="0"
                                Canvas.Top="0"
                                Width="25"
                                Height="25" />
                        </Canvas>
                    </Grid>
                    <Grid>
                        <TabControl Style="{DynamicResource TabControlStyle1}">
                            <TabItem Header="Tab 1" Style="{DynamicResource TabItemStyle1}">
                                <!--  Tab 1 的内容  -->
                                <Grid>
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Text=" Tab 1 的内容" />
                                </Grid>
                            </TabItem>

                            <TabItem Header="Tab 2">
                                <!--  Tab 2 的内容  -->
                                <Grid>
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Text=" Tab 2 的内容" />
                                </Grid>
                            </TabItem>
                        </TabControl>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <ToggleButton
                            Content="开始"
                            Style="{StaticResource ToggleButtonStyle}"
                            Tag="结束" />
                        <Button
                            Grid.Column="1"
                            Width="100"
                            Height="30"
                            Background="yellow"
                            Content="椭圆">
                            <Button.Template>
                                <ControlTemplate>
                                    <Grid>
                                        <Ellipse>
                                            <Ellipse.Fill>
                                                <SolidColorBrush Color="{Binding Path=Background.Color, RelativeSource={RelativeSource Mode=TemplatedParent}}" />
                                            </Ellipse.Fill>
                                        </Ellipse>
                                    </Grid>
                                </ControlTemplate>
                            </Button.Template>
                            <!--<Button.Style>
                                <Style TargetType="{x:Type Button}">
                                    <Setter Property="Background" Value="Green" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type Button}">
                                                <Grid>
                                                    <Ellipse>
                                                        <Ellipse.Fill>
                                                            <SolidColorBrush Color="{Binding Path=Background.Color, RelativeSource={RelativeSource Mode=TemplatedParent}}" />
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                </Grid>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>-->
                        </Button>
                    </Grid>
                    <!--  低性能，高cpu占用  -->
                    <!--<ListBox Height="300" ItemsSource="{Binding ImageList}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Image
                                    Width="200"
                                    Height="200"
                                    Source="{Binding}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>-->
                    <!--  高性能，低cpu占用  -->
                    <ListBox Height="400" ItemsSource="{Binding ImagePathList}">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <local:DisposableVirtualizingStackPanel IsVirtualizing="True" VirtualizationMode="Recycling" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <local:ImageDrawingVisual
                                    Width="700"
                                    Height="300"
                                    Source="{Binding}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </ScrollViewer>
        </Grid>
        <!--  顶部消息提示  -->
        <Grid
            Width="500"
            Height="100"
            Margin="0,300,0,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel
                x:Name="TopTips"
                Grid.Column="1"
                usercontrols:TipBar.Direction="Top"
                usercontrols:TipBar.EnterPostion="-150"
                usercontrols:TipBar.EnterStyle="Vertical"
                usercontrols:TipBar.HAligin="Center"
                usercontrols:TipBar.MaxTipCount="1"
                usercontrols:TipBar.WaitTime="2" />
        </Grid>
    </Grid>
</Window>
