                            <StackPanel HorizontalAlignment="Center" Orientation="Vertical">
                                <Button
                                    x:Name="CornerButton3"
                                    Height="50"
                                    usercontrols:CornerButton3.CornerButton3="{Binding MyCorner, Mode=TwoWay}"
                                    Content="附加属性2"
                                    Style="{StaticResource CustomButtonStyle3}" />
                                <TextBox Text="{Binding MyCorner}" />
